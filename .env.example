# URL interne du backend Clenzy (réseau docker) — consommé côté serveur uniquement.
CLENZY_API_BASE_URL=http://clenzy-server:8080

# Suffixe des sous-domaines de sites.
CLENZY_SITES_BASE_DOMAIN=clenzy.site

# Base API publique pour le widget de réservation monté côté client (BaitlyWidget).
NEXT_PUBLIC_WIDGET_BASE_URL=https://app.clenzy.fr
